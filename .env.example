# Copy this file to .env and fill in the values
# cp .env.example .env

# ─── DRIAMS Dataset Root Path ─────────────────────────────────────────────────
# Absolute path to the folder containing DRIAMS-A, DRIAMS-B, DRIAMS-C, DRIAMS-D
DRIAMS_ROOT=./data/driams

# ─── MLflow Tracking ──────────────────────────────────────────────────────────
MLFLOW_TRACKING_URI=./outputs/mlruns

# ─── Random Seed ──────────────────────────────────────────────────────────────
RANDOM_SEED=42
